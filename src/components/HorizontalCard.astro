---
const { title, img, desc, url, badge, tags, target = "_self" } = Astro.props;
import { Image } from "astro:assets";
import createSlug from "../lib/createSlug";

const tag_url = "/blog/tag";
---

<div class="rounded-lg bg-base-100 hover:shadow-xl transition ease-in-out hover:scale-[102%]">
  <a href={url} target={target}>
    <div class="hero-content flex-col md:flex-row">

      {img && (
        <Image
          src={img}
          width={750}
          height={422}
          format="webp"
          alt={title}
          class="max-w-full md:max-w-[13rem] rounded-lg"
        />
      )}

      <div class="grow w-full">
        <h2 class="text-xl font-bold">
          {title}
          {badge && <span class="badge badge-secondary mx-2">{badge}</span>}
        </h2>

        <p class="py-1">{desc}</p>

        <div class="card-actions justify-end">
          {tags &&
            tags.map((tag) => (
              <a
                href={`${tag_url}/${createSlug(tag)}`}
                class="badge badge-outline"
              >
                {tag}
              </a>
            ))}
        </div>
      </div>

    </div>
  </a>
</div>