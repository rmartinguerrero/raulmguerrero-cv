---
import SideBarFooter from "./SideBarFooter.astro";
import SideBarMenu from "./SideBarMenu.astro";

const currentPath = Astro.url.pathname;
const isCVPage = currentPath.startsWith("/cv");

// Detectar idioma simple por ruta
const isItalian = currentPath.startsWith("/it");
const homeLink = isItalian ? "/it/" : "/";
---

<div class="drawer-side z-40">
  <label for="my-drawer" class="drawer-overlay"></label>

  <aside class="px-4 pt-2 h-auto min-h-full w-[16rem] bg-base-100 text-base-content flex flex-col">

    <!-- TOP BAR -->
    <div class="flex justify-between items-center mb-4">

      <button id="theme-toggle" class="btn btn-ghost btn-xs">
        🌗
      </button>

      <div class="text-xs flex gap-2 items-center font-medium">
        <a href="/" class="hover:opacity-70">🇪🇸</a>
        <span>|</span>
        <a href="/it/" class="hover:opacity-70">🇮🇹</a>
      </div>

    </div>

    <!-- LOGO RMG -->
    <div class="mx-auto mb-8 relative">

      <a href={homeLink} class="block relative w-fit mx-auto group">

        <!-- Cuadrado verde externo (Ampliado a 6rem para mejor centrado) -->
        <div class="absolute -top-1 left-1/2 -translate-x-1/2 w-[6rem] h-[6rem] border-2 border-primary pointer-events-none transition-colors duration-300 group-hover:bg-primary/5"></div>

        <!-- Contenedor de Icono + Texto (Centrado absoluto dentro del área del cuadrado) -->
        <div class="relative w-[6rem] h-[6rem] flex flex-col items-center justify-center pt-1">
          
          <!-- Icono Disquete (Sutil y centrado) -->
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary mb-2 opacity-90">
              <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
              <polyline points="17 21 17 13 7 13 7 21"></polyline>
              <polyline points="7 3 7 8 15 8"></polyline>
          </svg>

          <!-- RMG perfectamente centrado (Ajuste de margen izquierdo para compensar el tracking) -->
          <div class="text-3xl font-bold tracking-[0.25em] leading-none ml-[0.25em]">
            RMG
          </div>
          
        </div>

      </a>

    </div>

    <SideBarMenu />
    <SideBarFooter />

  </aside>
</div>

<style>
/* ANIMACIÓN tipo codificación al entrar en CV */
.cv-glitch {
  position: relative;
  animation: code-glitch 0.4s ease-in-out;
}

@keyframes code-glitch {
  0% { 
    opacity: 0.4;
    letter-spacing: 0.4em;
    filter: blur(1px);
  }
  40% { 
    transform: translateX(-2px);
  }
  60% { 
    transform: translateX(2px);
  }
  100% { 
    opacity: 1;
    letter-spacing: 0.25em;
    filter: blur(0);
  }
}
</style>

<script is:inline>
  function initThemeToggle() {
    const toggle = document.getElementById("theme-toggle");
    if (!toggle) return;

    toggle.onclick = () => {
      const html = document.documentElement;
      const current = html.getAttribute("data-theme");
      const newTheme = current === "forest" ? "nord" : "forest";

      html.setAttribute("data-theme", newTheme);
      localStorage.setItem("theme", newTheme);
    };
  }

  function applyCVAnimation() {
    if (window.location.pathname.startsWith("/cv")) {
      const logo = document.querySelector(".tracking-\\[0\\.25em\\]");
      if (logo) {
        logo.classList.add("cv-glitch");
        setTimeout(() => {
          logo.classList.remove("cv-glitch");
        }, 400);
      }
    }
  }

  initThemeToggle();
  applyCVAnimation();

  document.addEventListener("astro:page-load", () => {
    initThemeToggle();
    applyCVAnimation();
  });
</script>